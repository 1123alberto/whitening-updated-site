# ====================================================================
# i-smile.gr -> dentplant.gr 301 Redirects
# Purpose: Maintain SEO value and redirect legacy i-smile traffic 
# to the corresponding treatment pages on the new Dentplant site.
# ====================================================================

# Enable Rewrite Engine
RewriteEngine On
RewriteBase /

# 1. SPECIFIC TREATMENT MAPPING (High Priority for SEO)
# --------------------------------------------------------------------

# Teeth Whitening -> Aesthetics page
RewriteRule ^whitening\.html$ https://www.dentplant.gr/aesthetics.html [R=301,NC,L]

# Porcelain Veneers -> Aesthetics page
RewriteRule ^veneers\.html$ https://www.dentplant.gr/aesthetics.html [R=301,NC,L]

# Clear Aligners -> Dedicated Aligners page
RewriteRule ^aligners\.html$ https://www.dentplant.gr/clear-aligners.html [R=301,NC,L]


# 2. FUNCTIONAL PAGES MAPPING
# --------------------------------------------------------------------

# Booking and Appointment Management -> Booking page
RewriteRule ^book\.html$ https://www.dentplant.gr/booking.html [R=301,NC,L]
RewriteRule ^manage\.html$ https://www.dentplant.gr/booking.html [R=301,NC,L]

# Privacy Policy -> Privacy page
RewriteRule ^privacy\.html$ https://www.dentplant.gr/privacy.html [R=301,NC,L]


# 3. ROOT & CATCH-ALL REDIRECT
# --------------------------------------------------------------------

# This section ensures all 4 variations are covered:
# http://i-smile.gr, https://i-smile.gr, http://www.i-smile.gr, https://www.i-smile.gr

# 3a. Specific Root Redirects (Home Page)
RewriteRule ^$ https://www.dentplant.gr/index.html [R=301,NC,L]
RewriteRule ^index\.html$ https://www.dentplant.gr/index.html [R=301,NC,L]

# 3b. Global Catch-all safety net
# Redirects any other path/asset from any i-smile.gr variation to the new home page.
RewriteCond %{HTTP_HOST} ^(www\.)?i-smile\.gr$ [NC]
RewriteRule ^(.*)$ https://www.dentplant.gr/index.html [R=301,L]
